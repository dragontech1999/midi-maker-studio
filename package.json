{
  "name": "midi-maker-studio",
  "productName": "MIDI Maker Studio",
  "private": true,
  "version": "1.3.0",
  "description": "Professional MIDI song generator with Magenta AI, offline models, and stem export",
  "author": "MIDI Maker Studio",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "icons": "node scripts/generate-icon.mjs",
    "electron:build": "npm run icons && tsc -b && vite build && electron-builder",
    "electron:build:win": "npm run icons && tsc -b && vite build && electron-builder --win",
    "electron:build:mac": "npm run icons && tsc -b && vite build && electron-builder --mac",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.midimakerstudio.app",
    "productName": "MIDI Maker Studio",
    "directories": {
      "output": "release-v130",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      { "from": "build/icon.png", "to": "icon.png" }
    ],
    "forceCodeSigning": false,
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        { "target": "portable", "arch": ["x64"] },
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "mac": {
      "icon": "build/icon.png",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.music"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "MIDI Maker Studio v${version} Portable.exe"
    }
  },
  "dependencies": {
    "@magenta/music": "^1.23.1",
    "@tonejs/midi": "^2.0.28",
    "jszip": "^3.10.1",
    "tone": "^15.0.4"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.7.1",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^2.1.8",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sharp": "^0.34.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7"
  }
}
